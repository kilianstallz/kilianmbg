---
import Layout from '../layouts/Layout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": "Kilian Minichberger",
    "url": "https://kilianmbg.dev",
    "jobTitle": "Software Engineer",
    "worksFor": { "@type": "Organization", "name": "Findustrial" },
    "knowsAbout": ["TypeScript", "Go", "C#", "Astro", "Cloud-native software", "GraphQL"],
    "sameAs": [
      "https://github.com/kilianstallz",
      "https://bsky.app/profile/kilianstallz.dev",
      "https://www.linkedin.com/in/kilian-minichberger-9815a5169"
    ]
  }
};
---

<Layout
  title="About"
  description="Kilian Minichberger — Software Engineer at Findustrial. Building cloud-native software, data pipelines, backend services, and great user experiences."
  jsonLd={jsonLd}
>
  <div class="about-page">
    <h1>About</h1>
    <p>
      Hi — I'm Kilian Minichberger (formerly Kilian Stallinger). I'm a software
      engineer focused on cloud-native software, data processing, backend services,
      and great user experiences. I have experience across full-stack development,
      backend services, and static site tooling.
    </p>

    <h2>Currently</h2>
    <p>Software Engineer at Findustrial · Building internal tools and backend services.</p>

    <h2>Skills</h2>
    <ul>
      <li>TypeScript, Go, C#</li>
      <li>Static sites, Astro, Tailwind, Solid</li>
      <li>APIs, GraphQL, backend systems</li>
    </ul>

    <h2>Links</h2>
    <ul>
      <li><a href="https://github.com/kilianstallz" target="_blank" rel="noopener">GitHub — kilianstallz</a></li>
      <li><a href="https://bsky.app/profile/kilianstallz.dev" target="_blank" rel="noopener">Bluesky — kilianstallz.dev</a></li>
      <li><a href="https://www.linkedin.com/in/kilian-minichberger-9815a5169" target="_blank" rel="noopener">LinkedIn</a></li>
    </ul>
  </div>
</Layout>
