---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const posts = await getCollection('articles') as any;
---

<Layout>
  <section class="py-12">
    <h1 class="text-4xl font-extrabold">Kilian Minichberger</h1>
    <p class="mt-4 text-gray-600 max-w-xl">Developer — building small, fast web experiences. Formerly Fullstack at Devjobs.at; currently Software Engineer at Findustrial. I normally focus on cloud native software, flowing data & great user experiences.</p>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <a class="px-4 py-2 bg-black text-white rounded-md" href="/articles">Articles</a>
      <a class="px-4 py-2 border border-gray-200 rounded-md text-gray-700" href="/about">About</a>
      <a class="px-4 py-2 border border-gray-200 rounded-md text-gray-700" href="https://github.com/kilianstallz" target="_blank" rel="noopener">GitHub</a>
      <a class="px-4 py-2 border border-gray-200 rounded-md text-gray-700" href="https://bsky.app/profile/kilianstallz.dev" target="_blank" rel="noopener">Bluesky</a>
      <a class="px-4 py-2 border border-gray-200 rounded-md text-gray-700" href="https://www.linkedin.com/in/kilian-minichberger-9815a5169" target="_blank" rel="noopener">LinkedIn</a>
    </div>
  </section>

  <section class="py-8">
    <h2 class="text-2xl font-semibold">Latest writing</h2>
    <ul class="mt-4 space-y-4">
      {posts.slice(0,3).map(({slug, data}) => (
        <li>
          <a class="block" href={`/articles/${slug}`}>
            <div class="text-lg font-medium">{data.title}</div>
            <div class="text-sm text-gray-500">{data.description}</div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
