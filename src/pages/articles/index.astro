---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('articles')).sort(
  (a, b) => new Date(b.data.pubDate ?? 0).getTime() - new Date(a.data.pubDate ?? 0).getTime()
);
---

<Layout
  title="Writing"
  description="Articles on software engineering, cloud-native development, AI tooling, and the web — by Kilian Minichberger."
>
  <div class="writing-page">
    <p class="section-label">Writing</p>
    <ul class="article-list">
      {posts.map((p) => (
        <li class="article-card">
          <a href={`/articles/${p.id}`}>
            <span class="article-card-title">{p.data.title}</span>
            <span class="article-card-date">{p.data.pubDate}</span>
            {p.data.description && (
              <span class="article-card-desc">{p.data.description}</span>
            )}
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>
